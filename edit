#!/bin/zsh

list_bin() {
	ls --color=auto $HOME/bin
}

echo 'TODO: Fix this command --options'

# if $1 -> Empty
test -z "$1" && cd $HOME/bin && return 1

# $1 -> file under ~/bin to be opened
nano $HOME/bin/$1
chmod +x $HOME/bin/$1
return 0

if [ -z "$1" ]; then
	$HOME/bin

if [ "$1" = "-p" -o "$1" = "--print" ]; then
	ls --color=auto $HOME/bin

elif [ "$1" = "-h" -o "$1" = "--help" ]; then
	echo "Helpfile - Gut's Utils"
	echo "Manage pretty help docs for your commands."

	#bat -p $HOME/bin/assets/edit.help.txt
	# Call the helpfile command here :D : $ helpfile -p [--print] edit
else
	# $1 -> file under ~/bin to be opened
	nano $HOME/bin/$1
fi
